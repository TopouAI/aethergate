# Run ./init-env.sh to generate .env automatically.
# The values below are examples only. Never commit a real .env file.

TZ=Asia/Shanghai

POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_HOST_PORT=5433
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_STATEMENT_TIMEOUT=120s
POSTGRES_IDLE_TX_TIMEOUT=60s
POSTGRES_SLOW_QUERY_MS=2000
POSTGRES_SHM_SIZE=512mb

LITELLM_DB_PASSWORD=CHANGE_ME
AETHERGATE_DB_PASSWORD=CHANGE_ME

PGBOUNCER_IMAGE=edoburu/pgbouncer:v1.25.2-p0
PGBOUNCER_ADMIN_PASSWORD=CHANGE_ME
PGBOUNCER_BIND_IP=127.0.0.1
PGBOUNCER_HOST_PORT=6432

REDIS_IMAGE=redis:7.4-alpine
REDIS_PASSWORD=CHANGE_ME

LITELLM_IMAGE=ghcr.io/berriai/litellm-non_root:v1.92.0
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_SALT_KEY=sk-salt-CHANGE_ME
LITELLM_BIND_IP=0.0.0.0
LITELLM_HOST_PORT=4000
LITELLM_NUM_WORKERS=1

# Safe default: direct PostgreSQL for LiteLLM schema initialization/upgrades.
# Optional after successful initialization: change host to pgbouncer.
LITELLM_DB_HOST=postgres
LITELLM_DB_PORT=5432
LITELLM_DB_CONNECTION_LIMIT=20

UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME
